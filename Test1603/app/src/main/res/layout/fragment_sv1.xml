<?xml version="1.0" encoding="utf-8"?>
    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Nhập Thông Tin Sinh Viên"
                android:textSize="22sp"
                android:textStyle="bold"
                    android:gravity="center"
                    android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtMaSv"
                android:hint="Mã sinh viên"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtTenSv"
                android:hint="Tên sinh viên"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"/>

            <TextView
                android:text="Giới tính"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/rgGender"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rbNam"
                    android:layout_width="128dp"
                    android:layout_height="wrap_content"
                    android:text="Nam" />

                <RadioButton
                    android:id="@+id/rbNu"
                    android:layout_width="121dp"
                    android:layout_height="wrap_content"
                    android:text="Nữ" />
            </RadioGroup>

            <TextView
                android:text="Sở thích"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <CheckBox
                android:id="@+id/cbGame"
                android:layout_width="128dp"
                android:layout_height="28dp"
                android:text="Chơi game" />

            <CheckBox
                android:id="@+id/cbMusic"
                android:layout_width="128dp"
                android:layout_height="28dp"
                android:text="Nghe nhạc"/>
            <CheckBox
                android:id="@+id/cbSport"
                android:layout_width="128dp"
                android:layout_height="28dp"
                android:text="Thể thao"/>
            <Button
                android:id="@+id/btnNhap"
                android:text="Nhập"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </ScrollView>