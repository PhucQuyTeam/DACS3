<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:text="Thông tin cá nhân"
                android:textColor="@color/primary_green"
                android:textSize="26sp"
                android:textStyle="bold" />

        <!-- 1. KHUNG ẢNH ĐẠI DIỆN -->
        <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="32dp">

            <ImageView
                    android:id="@+id/imgEditAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/logoaquariumshop" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#66000000"
                    android:gravity="center"
                    android:paddingVertical="4dp"
                    android:text="Thay ảnh"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
        </FrameLayout>

        <!-- 2. Ô NHẬP HỌ VÀ TÊN -->
        <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Họ và Tên"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeColor="@color/primary_green"
                app:startIconTint="@color/primary_green">

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 3. Ô EMAIL (BỊ KHÓA NHƯNG VẪN ĐẸP) -->
        <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Email (Tài khoản)"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeColor="#B0BEC5"> <!-- Viền xám mờ nhẹ -->

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:longClickable="false"
                    android:cursorVisible="false"
                    android:textColor="#9E9E9E"
                    android:inputType="textEmailAddress" />
            <!-- focusable="false": Chặn không cho bàn phím bật lên -->
            <!-- textColor="#9E9E9E": Màu chữ xám để biết là bị khóa -->
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 4. Ô NHẬP SỐ ĐIỆN THOẠI -->
        <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:hint="Số điện thoại"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeColor="@color/primary_green"
                app:startIconTint="@color/primary_green">

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 5. NÚT LƯU THÔNG TIN -->
        <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Lưu thay đổi"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_green"
                app:cornerRadius="30dp" />

    </LinearLayout>
</ScrollView>