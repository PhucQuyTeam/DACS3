<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        xmlns:tools="http://schemas.android.com/tools"
        tools:context=".ui.home.ProductDetailFragment"
        android:background="#F5F5F5"> <!-- Nền xám nhạt để tách biệt các section -->

    <!-- THANH CÔNG CỤ (TOP BAR) Ở ĐÂY (Nút Back, Giỏ hàng...) -->

    <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomActionBar">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- 1. KHỐI THÔNG TIN CƠ BẢN (Ảnh, Giá, Tên, Danh mục) -->
            <include layout="@layout/layout_detail_info" />

            <!-- 2. KHỐI MÔ TẢ SẢN PHẨM -->
            <include layout="@layout/layout_detail_description" />

            <!-- 3. KHỐI ĐÁNH GIÁ (Tổng quan & Nút Xem tất cả) -->
            <include layout="@layout/layout_detail_reviews" />

            <!-- Khoảng trống ở đáy để khi cuộn không bị che bởi thanh mua hàng -->
            <View android:layout_width="match_parent" android:layout_height="20dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- THANH BOTTOM ACTION BAR (Cố định ở đáy) -->
    <LinearLayout
            android:id="@+id/bottomActionBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:elevation="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <!-- CỤM 1: BỘ CHỌN SỐ LƯỢNG -->
        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:background="#E8F5E9"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

            <!-- Nút Giảm (-) -->
            <TextView
                    android:id="@+id/btnDecreaseQty"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#757575"
                    android:background="#F5F5F5"
                    android:clickable="true"
                    android:focusable="true"/>

            <!-- Ô hiển thị số lượng hiện tại -->
            <TextView
                    android:id="@+id/tvCurrentQuantity"
                    android:layout_width="40dp"
                    android:layout_height="32dp"
                    android:background="#F5F5F5"
                    android:text="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:gravity="center"/>

            <!-- Nút Tăng (+) -->
            <TextView
                    android:id="@+id/btnIncreaseQty"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#212121"
                    android:background="#F5F5F5"
                    android:clickable="true"
                    android:focusable="true"/>
        </LinearLayout>

        <!-- Kẻ vạch mờ phân cách -->
        <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="8dp"
                android:background="#E0E0E0"/>

        <!-- CỤM 2: Nút Thêm vào giỏ hàng -->
        <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Thêm vào giỏ"
                android:textColor="#2E7D32"
                android:textSize="13sp"
                app:backgroundTint="#E8F5E9"
                app:cornerRadius="0dp"
                app:icon="@drawable/ic_giohang"
                app:iconTint="#2E7D32"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

        <!-- CỤM 3: Nút Mua Ngay -->
        <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyNow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Mua ngay"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                app:backgroundTint="#FF5722"
                app:cornerRadius="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
